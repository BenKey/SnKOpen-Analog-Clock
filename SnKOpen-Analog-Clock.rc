//
// Menu
//

IDC_APP MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                       IDM_EXIT
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About ...",                  IDM_ABOUT
    END
    POPUP "&Options"
    BEGIN
        MENUITEM "Use &Default",                IDM_OPTIONS_USE_DEFAULT
        MENUITEM "&Edit Options...",            IDM_OPTIONS_EDIT_OPTIONS
    END
END

