    LTEXT           "",IDC_CURRENT_BACKGROUND_COLOR_STATIC,164,10,20,20,WS_BORDER | NOT WS_GROUP,WS_EX_STATICEDGE
    PUSHBUTTON      "Choose Clock Color...",IDC_CHOOSE_CLOCK_COLOR_BUTTON,10,34,146,20
    LTEXT           "",IDC_CURRENT_CLOCK_COLOR_STATIC,164,34,20,20,WS_BORDER | NOT WS_GROUP,WS_EX_STATICEDGE
    DEFPUSHBUTTON   "OK",IDOK,42,62,50,14
